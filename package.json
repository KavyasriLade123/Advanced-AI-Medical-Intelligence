{
  "name": "advanced-ai-medical-intelligence-platform",
  "private": true,
  "version": "1.0.0",
  "description": "MedIntel — Advanced AI Medical Intelligence Platform",
  "scripts": {
    "dev": "npm run dev --prefix frontend -- --host 0.0.0.0 --port 5173",
    "dev:frontend": "npm run dev --prefix frontend -- --host 0.0.0.0 --port 5173",
    "dev:backend": "cd backend && .venv\\Scripts\\uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build --prefix frontend",
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "cd backend && .venv\\Scripts\\pip install -r requirements.txt"
  }
}
